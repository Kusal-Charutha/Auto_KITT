<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="@drawable/bg_card_outline_red"
    android:padding="16dp"
    android:layout_marginBottom="12dp">

    <!-- Severity indicator dot -->
    <View
        android:id="@+id/viewSeverityDot"
        android:layout_width="10dp"
        android:layout_height="10dp"
        android:layout_marginTop="5dp"
        android:layout_marginEnd="12dp"
        android:background="@drawable/shape_dot"
        android:backgroundTint="@color/warning_yellow" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvAlertTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Timestamp"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/tvAlertSeverity"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="WARNING"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="@color/warning_yellow"
            android:layout_marginBottom="6dp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tvAlertExplanation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Explanation text"
            android:textColor="#333333"
            android:textSize="14sp"/>

        <TextView
            android:id="@+id/tvAlertAdvice"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Advice text"
            android:textColor="#666666"
            android:textSize="13sp"
            android:textStyle="italic"
            android:layout_marginTop="6dp"
            android:drawablePadding="4dp"
            android:visibility="gone" />

    </LinearLayout>
</LinearLayout>
