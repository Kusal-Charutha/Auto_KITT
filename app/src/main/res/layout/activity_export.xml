<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:paddingStart="24dp"
    android:paddingEnd="24dp"
    android:paddingBottom="24dp"
    android:paddingTop="56dp"
    android:gravity="center_horizontal"
    android:background="@color/white">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="EXPORT\nDATA LOGS"
        android:textSize="24sp"
        android:textStyle="bold"
        android:gravity="center"
        android:textColor="@color/black"
        android:layout_marginTop="24dp"
        android:layout_marginBottom="48dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_button_white_pill"
        android:backgroundTint="@color/white"
        android:elevation="4dp"
        android:padding="24dp">

        <RadioGroup
            android:id="@+id/rgExportOptions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <RadioButton
                android:id="@+id/rbLastSession"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Last Driving session"
                android:textColor="@color/black"
                android:buttonTint="@color/blue_primary"
                android:textSize="16sp"
                android:padding="12dp"
                android:checked="true"/>

            <RadioButton
                android:id="@+id/rbToday"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Today"
                android:textColor="@color/black"
                android:buttonTint="@color/blue_primary"
                android:textSize="16sp"
                android:padding="12dp"/>

            <RadioButton
                android:id="@+id/rbThisWeek"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="This Week"
                android:textColor="@color/black"
                android:buttonTint="@color/blue_primary"
                android:textSize="16sp"
                android:padding="12dp"/>

            <RadioButton
                android:id="@+id/rbAllTime"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="All time"
                android:textColor="@color/black"
                android:buttonTint="@color/blue_primary"
                android:textSize="16sp"
                android:padding="12dp"/>

        </RadioGroup>

        <Button
            android:id="@+id/btnExportAction"
            android:layout_width="200dp"
            android:layout_height="wrap_content"
            android:text="Export"
            android:textColor="@color/white"
            android:background="@drawable/bg_button_white_pill"
            android:backgroundTint="@color/blue_primary"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="24dp"/>

        <Button
            android:id="@+id/btnShareDebug"
            android:layout_width="200dp"
            android:layout_height="wrap_content"
            android:text="Share Debug Trace"
            android:textColor="@color/white"
            android:background="@drawable/bg_button_white_pill"
            android:backgroundTint="@color/surface_lighter"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="12dp"/>

    </LinearLayout>

</LinearLayout>
